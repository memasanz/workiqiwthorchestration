# Copy this file to .env and fill in the values for your environment.
# `azd up` reads these via `infra/main.bicepparam` (using readEnvironmentVariable).
# `.env` is gitignored.

# ── azd-managed (set automatically by `azd init` / `azd env new`) ────────────
# azd convention: <prefix>-<env>. Used by azd to name the env folder.
# Only the env suffix matters for resource naming (the bicep dedupes if
# you give it the full name).
AZURE_ENV_NAME=mpwflow-dev
AZURE_LOCATION=eastus2
AZURE_SUBSCRIPTION_ID=

# Short prefix used for both Azure resource names (rg-<prefix>-*, ca-<prefix>-*)
# and the Entra app reg names (<prefix>-api, <prefix>-spa) created by
# scripts/admin/setup-entra.ps1. 3-12 chars, letters/digits.
AZURE_BASE_NAME=mpwflow

# ── Foundry (manual prereq — created by an admin in the Foundry portal) ─────
# Format: https://<aif-account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=https://CHANGE_ME.services.ai.azure.com/api/projects/CHANGE_ME

# Model deployment name in the Foundry project (e.g. gpt-4o-mini).
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# ── Entra (output of scripts/admin/setup-entra.ps1) ─────────────────────────
ENTRA_TENANT_ID=
ENTRA_BACKEND_APP_ID=
ENTRA_SPA_APP_ID=

# ── chat-api dev knobs ──────────────────────────────────────────────────────
# Set to "true" only for local debugging; allows ?as_user= in lieu of a JWT.
CHAT_API_DEV_BYPASS_AUTH=false
